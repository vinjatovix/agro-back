{
  "name": "agro-back",
  "version": "1.0.0",
  "description": "agro management back end",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "docker:mongo": "docker-compose -f ./docker/docker-compose.yml up --build -d",
    "restoreDB": "./docker/mongo/scripts/restoreDB.sh",
    "restoreDump": "./docker/mongo/scripts/restoreDump.sh",
    "dev": "tsx watch src/index.ts",
    "check-circular": "skott --displayMode=raw --showCircularDependencies --tsconfig ./tsconfig.json",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix --fix-type problem,layout,suggestion",
    "format": "prettier \"src/**/*.{ts,tsx,js,jsx,json,md}\" --write",
    "build": "npm run build:clean && npm run build:validate-routes && npm run build:tsc && npm run build:di",
    "build:clean": "rm -r dist; exit 0",
    "build:validate-routes": "tsx ./scripts/validate-routes.ts",
    "build:di": "find ./src -type f \\( -name '*.json' -o -name '*.yml' -o -name '*.yaml' -o -name '*.html' -o -name '*.png' -o -name '*.env' \\) -exec cp --parents {} dist/ \\;",
    "build:tsc": "tsc -p tsconfig.prod.json --sourceMap false",
    "test": "npm run build && npm run test:clean:coverage && npm run test:unit && npm run test:features && npm run test:merge:coverage",
    "test:clean:coverage": "rm -rf coverage && rm -rf .c8_output",
    "test:unit": "jest --detectOpenHandles --forceExit",
    "test:unit:watch": "jest --watch --detectOpenHandles --forceExit",
    "test:features": "cross-env NODE_ENV=test NODE_OPTIONS='--loader ts-node/esm' c8 --report-dir=coverage/cucumber cucumber-js tests/apps/agroApi/features/**/*.feature --import ./setupTests.ts --import ./tests/apps/agroApi/features/step_definitions/controller.steps.ts",
    "test:merge:coverage": "lcov-result-merger 'coverage/*/lcov.info' 'coverage/merged.info'",
    "prepare": "husky install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vinjatovix/agro-back.git"
  },
  "author": "vinjadevix",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vinjatovix/agro-back/issues"
  },
  "homepage": "https://github.com/vinjatovix/agro-back#readme",
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/chai": "^5.2.3",
    "@types/chance": "^1.1.7",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "chance": "^1.1.13",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "husky": "^8.0.0",
    "jest": "^30.3.0",
    "lcov-result-merger": "^5.0.1",
    "prettier": "^3.8.2",
    "skott": "^0.35.10",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/errorhandler": "^1.5.3",
    "@types/express": "^4.17.25",
    "awilix": "^13.0.3",
    "awilix-express": "^11.0.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "env-var": "^7.5.0",
    "errorhandler": "^1.5.2",
    "express": "^4.22.1",
    "express-promise-router": "^4.1.1",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.2",
    "glob": "^13.0.6",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.1",
    "uuid": "^11.1.0",
    "winston": "^3.19.0",
    "winston-mongodb": "^7.0.1"
  }
}
