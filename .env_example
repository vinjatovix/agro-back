PORT=3377
HOST=http://localhost
ALLOWED_ORIGINS=http://localhost:3377
JSON_BODY_LIMIT=1mb
URL_ENCODED_BODY_LIMIT=1mb
REQUEST_TIMEOUT_MS=30000
HEADERS_TIMEOUT_MS=35000
KEEP_ALIVE_TIMEOUT_MS=5000
NODE_ENV=test
MONGO_CONNECTION=mongodb
MONGO_URL=localhost:27017
